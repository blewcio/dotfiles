alias vi="vim"
# Don't remove, but shift to /tmp instead
alias rm="mv --target-directory /tmp/"
alias cr="rsync -P"
# mkdir incl. parent dirs if necessary
alias mkdir="mkdir -pv"
alias l='ls -CF'
alias l.='ls -d .*'
alias le='ls -l | less'
# Grep for a process
alias psg="ps aux | grep -v grep | grep -i -e VSZ -e"
#MyIP
alias myip="curl http://ipecho.net/plain; echo"
#Serve current directory tree at http://$HOSTNAME:8000/
alias lsw="python -m SimpleHTTPServer"
# Enable tmux to use 256 colors by default
alias tmux='tmux -2'
alias ta='tmux attach'
alias tn='tmux new'
# Simple calculator
# ? () { echo "$*" | bc -l; }
alias installed-packages="comm -23 <(apt-mark showmanual | sort -u) <(gzip -dc /var/log/installer/initial-status.gz | sed -n 's/^Package: //p' | sort -u)"
# fasd shortcuts
alias v='f -e vim'
alias m='f -e mplayer'
